# nbdpsy-mcp 环境变量样例。复制为 .env 并按需填入真实值。
# 每个字段对应 app/core/config.py 中的 Settings 字段（全部带默认值，可缺省）。

# 应用元信息
APP_NAME=nbdpsy-mcp
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API 服务监听
API_HOST=0.0.0.0
API_PORT=8848
PUBLIC_BASE_URL=http://127.0.0.1:8848

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/nbdpsy.db
# SQLite 忙等超时（秒）：并发写锁竞争时最多等待此秒数而非立即报 database is locked（仅 sqlite 生效）
SQLITE_BUSY_TIMEOUT=30

# 安全（生产必须替换为 >=32 字节随机值）
SECRET_KEY=change-me-32bytes-minimum-secret-key
ROOT_ADMIN_APIKEY=

# 数据/上传目录
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
# 图片上传:单张大小上限（MB）与批次保留天数
UPLOAD_MAX_MB=10
UPLOAD_TTL_DAYS=7

# 浏览器自动化（Xvfb 虚拟显示）
XVFB_DISPLAY=:99
# 全局浏览器并发闸：同时运行的 camoufox 数上限（超出排队等待）
BROWSER_CONCURRENCY=6

# 发布队列
PUBLISH_CONCURRENCY=2
PUBLISH_RETRY_SCHEDULE=120,600,1800
PUBLISH_JOB_TIMEOUT=600
# 账号级发布冷却(秒):同一账号两次发布最小间隔,每次 random.uniform(MIN,MAX) 现抽抖动
PUBLISH_MIN_INTERVAL_MIN=1200
PUBLISH_MIN_INTERVAL_MAX=3600
# 每账号每自然日发布上限:达上限的新任务顺延到次日活跃窗口
PUBLISH_DAILY_CAP=8
# 次日活跃窗口起点(UTC 小时,1=北京09:00)与抖动跨度(秒)
PUBLISH_ACTIVE_WINDOW_START_UTC_HOUR=1
PUBLISH_ACTIVE_WINDOW_JITTER_SEC=7200
# 只存草稿模式(默认 true):录入内容后不点发布,由编辑器自动存草稿,用户到草稿箱手动真人
# 发布,规避"点发布提交"时的「人机发布」风控封号。要恢复自动真发改 false。
PUBLISH_DRAFT_ONLY=true

# Cookie 巡检间隔（秒，0 表示关闭定时巡检）
COOKIE_CHECK_INTERVAL=0

# 孤儿 camoufox 回收：巡检间隔（秒，0 表示关闭）与超龄阈值（秒）
BROWSER_REAP_INTERVAL=300
BROWSER_REAP_AGE=900

# 占位废账号根治：A 服务端自愈窗口（分钟）、B TTL 兜底 reaper 间隔（秒，0=关闭）与占位存活上限（小时）
PLACEHOLDER_CLEAN_WINDOW_MINUTES=30
PLACEHOLDER_REAP_INTERVAL=3600
PLACEHOLDER_TTL_HOURS=24

# 调试截图开关
DEBUG_SCREENSHOTS_ENABLED=false

# 选择器自愈（可选，默认关）。开启需 SELFHEAL_ENABLED=true 且填 LLM_API_KEY
SELFHEAL_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-flash
LLM_TIMEOUT=15

# ── 视频管线：DashScope（ASR/翻译/LLM/VL 共用一把 apikey）──
# ASR 走 dashscope SDK 自带端点；翻译/LLM/VL 走下面的 compatible-mode（openai 兼容）base_url。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VIDEO_ASR_MODEL=paraformer-v2
# transport 下载时长闸门（秒，超此时长拒收；默认 2h）
VIDEO_TRANSPORT_MAX_DURATION_SECONDS=7200
VIDEO_MT_MODEL=qwen-mt-plus
VIDEO_LLM_MODEL=qwen3.7-plus
VIDEO_VL_MODEL=qwen-vl-max

# ── 视频管线：豆包语音 TTS（声音复刻 v3 / seed-icl-2.0）──
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=
# 默认复刻音色（牧羊，实测自然度优于 cosyvoice）
DOUBAO_TTS_VOICE=S_hoiqVFN72
DOUBAO_TTS_RESOURCE_ID=seed-icl-2.0
# transport dub 全片统一语速上限（倍率；到顶仍溢出则接受残余+告警；默认 1.2）
TTS_MAX_RATE=1.2

# ── 一致性生图（gpt-image-2 锚点法，自薯营家迁移）──
# OpenAI Images API；BASE_URL 可指向国内中转，PROXY 非空再叠 HTTP 代理
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
# 质量档：medium 为质量/成本平衡点（8 页约 $0.68）
OPENAI_IMAGE_QUALITY=medium
# 单张生图调用超时（秒）
OPENAI_IMAGE_TIMEOUT=300
OPENAI_IMAGE_PROXY=

# ── 视频 worker 调度（方案 C 独立 asyncio worker）──
# 单机 CPU 编码并发 1；阶段内 300s 周期 touch heartbeat_at；恢复扫描判僵死阈值 900s(15min)
VIDEO_WORKER_CONCURRENCY=1
VIDEO_HEARTBEAT_INTERVAL=300
VIDEO_STALE_TIMEOUT=900
